# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real keys.

# API key for the community preset upload endpoint.
# Generate with: openssl rand -hex 16
# Must match the value set in upload-preset.php on the server (KB1_PRESET_API_KEY env var,
# or hardcoded directly if your host doesn't support PHP env vars).
# Also add this as a GitHub Actions secret named VITE_PRESET_API_KEY.
VITE_PRESET_API_KEY=your-generated-key-here
