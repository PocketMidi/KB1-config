# KB1 Community Presets - CORS & Security Configuration
# Upload to: public_html/presets/.htaccess on pocketmidi.com

<IfModule mod_headers.c>
    # Enable CORS for all origins (required for localhost dev and deployed app)
    Header set Access-Control-Allow-Origin "*"
    
    # Allow GET and OPTIONS methods
    Header set Access-Control-Allow-Methods "GET, OPTIONS"
    
    # Allow standard headers
    Header set Access-Control-Allow-Headers "Content-Type"
    
    # Cache preflight requests for 24 hours
    Header set Access-Control-Max-Age "86400"
</IfModule>

# Force JSON content type
<FilesMatch "\.json$">
    <IfModule mod_headers.c>
        Header set Content-Type "application/json; charset=utf-8"
    </IfModule>
</FilesMatch>

# Enable gzip compression for JSON (improves load times)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# Security: Disable directory browsing
Options -Indexes

# Security: Deny access to hidden files (.git, .env, etc)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
